# =============================================================================
# Fanek Environment Configuration
# =============================================================================
#
# Docker users: You don't need this file! Just run: docker compose up -d
# The Docker entrypoint auto-generates secrets and connects to its own database.
#
# Manual install: Copy this file to .env and fill in the values below.
#   cp .env.example .env
#
# =============================================================================

# Database connection string
# Create a PostgreSQL 16+ database, then set the connection URL here.
# Example: postgresql://user:password@localhost:5432/fanek
DATABASE_URL="postgresql://fanek:fanek@localhost:5432/fanek"

# NextAuth.js session signing secret (REQUIRED for manual install)
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=""

# Application URL (REQUIRED for manual install)
# Must match how users access the app in their browser.
# Examples: http://localhost:8080, https://fanek.example.com
NEXTAUTH_URL="http://localhost:8080"

# Server port (optional, defaults to 8080)
# PORT=8080

# Node environment (optional, defaults to development)
# Set to "production" for production deployments
# NODE_ENV=development
