# =============================================================================
# Fanek Environment Configuration
# =============================================================================
#
# Docker users: You don't need this file! Just run: docker compose up -d
# The Docker entrypoint auto-generates NEXTAUTH_SECRET, provides DATABASE_URL,
# and connects to its own database. (You may still create a .env to override
# NEXTAUTH_URL or PORT — Docker Compose picks it up automatically.)
#
# Manual install: Copy this file to .env and fill in the values below.
#   cp .env.example .env
#
# Conventions used below:
#   - Values shown are DEVELOPMENT defaults, ready for `npm run dev`.
#   - Each setting notes what to change for PRODUCTION.
#   - Lines starting with `#` are optional/overrides; uncomment to use them.
#
# =============================================================================


# -----------------------------------------------------------------------------
# Core (required for manual install)
# -----------------------------------------------------------------------------

# Database connection string  (REQUIRED)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
#
# Development default below assumes a Postgres user "fanek" with password "fanek".
DATABASE_URL="postgresql://fanek:fanek@localhost:5432/fanek"
#
# macOS / Homebrew Postgres note:
#   `brew install postgresql` creates a superuser named after your macOS account
#   with NO password (peer/trust auth), and no "fanek" role. The line above will
#   fail with "password authentication failed" or "role fanek does not exist".
#   Either create the role/db to match the URL:
#       createuser -s fanek && createdb -O fanek fanek
#       psql -d fanek -c "ALTER USER fanek WITH PASSWORD 'fanek';"
#   ...or point the URL at your own account (replace YOURUSER):
#       DATABASE_URL="postgresql://YOURUSER@localhost:5432/fanek"
#
# Production: use a strong password, a dedicated database, and (ideally) require
# TLS, e.g. ...@db.internal:5432/fanek?sslmode=require

# NextAuth.js session signing secret  (REQUIRED)
# Used to sign/encrypt session tokens. A BLANK value crashes the app on startup
# and on the setup endpoint, so this must be set before you run the app.
# Generate one with:
#   openssl rand -hex 32
# (any long random string works; `openssl rand -base64 32` is also fine.)
# Production: keep this secret, unique per environment, and never commit it.
NEXTAUTH_SECRET=""

# Application URL  (REQUIRED)
# Must match how the browser reaches the app, or OAuth/login callbacks fail.
#
# Development default below matches `npm run dev` (which listens on port 3000).
NEXTAUTH_URL="http://localhost:3000"
#
# Note: `npm start` (manual production build) listens on port 8080, so for a
# local production build use http://localhost:8080 instead.
# Production: set this to your real, externally reachable HTTPS URL, e.g.
#   NEXTAUTH_URL="https://fanek.example.com"


# -----------------------------------------------------------------------------
# Server (optional)
# -----------------------------------------------------------------------------

# HTTP port.
# Manual install: the listening port is fixed by the npm scripts
#   (`npm run dev` -> 3000, `npm start` -> 8080); PORT does not change them.
# Docker: PORT controls the published port mapping (default 8080) and the
#   entrypoint's fallback NEXTAUTH_URL. Set it in .env to change the Docker port.
# PORT=8080

# Node environment. Defaults to "development".
# Affects logging (see LOG_LEVEL) and various dev-only behaviors.
# Production: set to "production".
# NODE_ENV=development


# -----------------------------------------------------------------------------
# Logging (optional)
# -----------------------------------------------------------------------------

# Pino log level: trace | debug | info | warn | error | fatal | silent
# Default: "debug" when NODE_ENV != production, otherwise "info".
# LOG_LEVEL=debug


# -----------------------------------------------------------------------------
# Database connection pool (optional)
# -----------------------------------------------------------------------------
# These tune the pg connection pool used by Prisma. Defaults are sensible for
# small deployments; raise the pool size for higher concurrency.

# Maximum number of connections in the pool. Default: 10
# DB_POOL_MAX=10

# Milliseconds an idle connection stays open before being closed. Default: 30000
# DB_POOL_IDLE_TIMEOUT=30000

# Milliseconds to wait when acquiring a new connection before erroring. Default: 5000
# DB_POOL_CONNECT_TIMEOUT=5000


# -----------------------------------------------------------------------------
# Reverse proxy (optional)
# -----------------------------------------------------------------------------

# Trust the X-Forwarded-For header for client IP. Defaults to off.
# Enable ONLY when running behind a reverse proxy you control (Caddy/Nginx/Traefik)
# that sets X-Forwarded-For. It makes the login rate limiter key on the real client
# IP. Leave off for direct exposure, where the header is spoofable.
# TRUST_PROXY=true


# -----------------------------------------------------------------------------
# Runtime tuning (optional)
# -----------------------------------------------------------------------------

# Standard Node.js option, honored by the runtime (not Fanek code). Use it to
# raise the heap limit on memory-constrained servers, e.g.:
# NODE_OPTIONS=--max-old-space-size=512
